{
  "name": "hiralearn",
  "private": true,
  "version": "0.1.0",
  "description": "HiraLearn — root workspace. Contains a Vite/React frontend (frontend/) and Supabase backend (backend/: migrations, edge functions, seeds).",
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "build:web": "npm run build:web --prefix frontend",
    "preview": "npm run preview --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "typecheck": "npm run typecheck --prefix frontend",
    "install:frontend": "npm install --prefix frontend",
    "db:diff": "supabase db diff --workdir backend",
    "db:push": "supabase db push --workdir backend",
    "db:reset": "supabase db reset --workdir backend"
  }
}
